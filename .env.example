# =============================================================================
# .env.example  ->  copy to .env and fill in.  `docker compose` reads .env.
# Every var below is referenced by docker-compose.yml. Do NOT commit .env.
# =============================================================================

# --- Postgres backing OneCLI's vault -----------------------------------------
ONECLI_DB_PASSWORD=change-me-strong-db-password

# --- OneCLI vault encryption key ---------------------------------------------
# MUST be: openssl rand -base64 32   --- and BACK IT UP. Lose it = lose the vault.
ONECLI_SECRET_ENCRYPTION_KEY=REPLACE_WITH_openssl_rand_base64_32

# --- LiteLLM ------------------------------------------------------------------
# Master key: any strong secret you choose (admin to the LiteLLM proxy).
LITELLM_MASTER_KEY=sk-litellm-master-change-me
# Virtual key the ZeroClaw tiers use to call LiteLLM. For the pilot you can set
# this to the SAME value as the master key (virtual keys need Postgres on LiteLLM,
# which is deferred to hardening — see PROJECT-STATE lesson #7).
LITELLM_VIRTUAL_KEY=sk-litellm-master-change-me

# --- PrivateMode (TEE inference) ---------------------------------------------
# Your real PrivateMode API key.
PRIVATEMODE_API_KEY=REPLACE_WITH_PRIVATEMODE_API_KEY

# --- OneCLI agent access tokens ------------------------------------------------
# Created via OneCLI dashboard (Settings -> Agents) after boot. Each identity gets
# a scoped aoc_ token. The required identities depend on your tiers.yaml config;
# the default setup needs 'personal' and 'tasks'. Add an entry for every identity
# you define in tiers.yaml (format: ONECLI_TOKEN_<UPPERCASE_IDENTITY_NAME>=...).
# See README for the dashboard flow.
ONECLI_TOKEN_PERSONAL=REPLACE_WITH_aoc_token_for_personal_identity
ONECLI_TOKEN_TASKS=REPLACE_WITH_aoc_token_for_tasks_identity

# --- MCP gateway tokens --------------------------------------------------------
# Shared secrets between gateways and ZeroClaw tiers. Generate one per MCP gateway
# with: openssl rand -base64 32. The var NAME must match the mcp_token_var field
# in tiers.yaml (default: MCP_<TIERNAME>_TOKEN).
MCP_PERSONAL_TOKEN=REPLACE_WITH_openssl_rand_base64_32
MCP_TASKS_TOKEN=REPLACE_WITH_openssl_rand_base64_32

# --- Multipass VM access (NOT used by docker compose) ---------------------------
# Your SSH PUBLIC key (the .pub, one line, QUOTED — it has spaces). launch-multipass.sh
# renders ONLY this public key into the VM's cloud-init (login key); the rest of .env
# is transferred into the VM after boot over multipass's channel, not via cloud-init.
SSH_PUBLIC_KEY="ssh-ed25519 AAAA_REPLACE_WITH_YOUR_PUBLIC_KEY you@mac"

# =============================================================================
# NOT in this file (set elsewhere):
#   * Real PrivateMode MODEL ID    -> litellm/config.yaml  (replace PLACEHOLDER)
#   * Per-tier SaaS credentials    -> OneCLI dashboard vault (Google->personal,
#                                     Marvin->tasks). Brokered; never in .env.
#   * Channel creds (WhatsApp/Signal) -> bound interactively via `zeroclaw channel`
# =============================================================================
