# =============================================================================
# Copy to ".env" (same folder as docker-compose.yml) and fill in.
# Keep .env OUT of git and OUT of the Portainer/Unraid UI plaintext fields.
# =============================================================================

# --- OneCLI ------------------------------------------------------------------
# 32-byte base64 key. Generate with:  openssl rand -base64 32
ONECLI_SECRET_ENCRYPTION_KEY=PLACEHOLDER_base64_32_bytes
ONECLI_DB_PASSWORD=PLACEHOLDER_strong_password
# API keys for the TWO OneCLI agent identities (create in dashboard after boot).
# Each is presented as Proxy-Authorization by its tier; OneCLI scopes creds per identity.
ONECLI_TOKEN_PERSONAL=oc_PLACEHOLDER_personal
ONECLI_TOKEN_TASKS=oc_PLACEHOLDER_tasks

# --- PrivateMode (TEE model provider) ---------------------------------------
PRIVATEMODE_API_KEY=PLACEHOLDER_privatemode_key

# --- LiteLLM -----------------------------------------------------------------
LITELLM_MASTER_KEY=sk-PLACEHOLDER_master
# Minted AFTER first boot via /key/generate (see litellm/config.yaml comment).
# This is what the agent uses as ANTHROPIC_AUTH_TOKEN.
LITELLM_VIRTUAL_KEY=sk-PLACEHOLDER_virtual
