# key=value; keys MUST match the `name` fields under each catalog secret.
# PLACEHOLDERS ONLY - OneCLI injects the real credential on egress.
# Putting the real Amazing Marvin key here would let the server hold a raw
# credential, breaking the ZeroClaw invariant. chmod 600 this file.
marvin_api_key=PLACEHOLDER_ONECLI_INJECTS
